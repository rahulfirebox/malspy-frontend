# Frontend URL — localhost or LAN IP (e.g. http://192.168.1.40:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_APP_NAME=SecureScan
NEXT_PUBLIC_APP_ENV=development

# Backend API — browser calls /api/v1/*, Next.js proxies here
BACKEND_URL=http://localhost:8082/api

# Poll /health/ready/ on dashboard — set false if backend is offline (reduces dev proxy errors)
NEXT_PUBLIC_ENABLE_API_HEALTH_CHECK=true
